# Dashboard 页面标题中的名称，显示为「notion-auto （NOTION_AUTO_NAME）控制台」；不设则为「notion-auto 控制台」
# NOTION_AUTO_NAME = 我的电脑

# Notion 任务队列：Integration Token，用于读写 Notion 数据库（拉取 Queued 任务、更新 Status）。未配置则仅运行 schedule 任务链。
# NOTION_API_KEY = secret_xxx

NOTION_SMTP_HOST = smtp.gmail.com
NOTION_SMTP_PORT = 587
NOTION_SMTP_USER = mark@fridgechannels.com
NOTION_SMTP_PASS = Bai188452..
NOTION_ALERT_TO = oh.duang@gmail.com

# Webhook 插队任务：POST /api/webhook/adhoc 校验用；不配置则该接口返回 503
# NOTION_AUTO_WEBHOOK_TOKEN=your-secret-token

# Webhook 插队：空闲账号上最多同时启动的「一次性子进程」个数（全局上限，保护内存）。
# 默认 3；达到上限时新任务会留在 queued，待有空位再分配。不影响已在运行账号的进程内消费。
# NOTION_AUTO_ADHOC_ONESHOT_MAX=3

# Dashboard「全部启动」时账号之间的错峰间隔（毫秒）；避免多个 Chromium 同秒争抢带宽/CPU/swap，
# 导致 Notion SPA 初刷相互拖累、page.goto 30s 超时。默认 5000；设为 0 则同时启动（老行为）。
# NOTION_AUTO_STARTUP_STAGGER_MS=5000