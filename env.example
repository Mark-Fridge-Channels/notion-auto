# Dashboard 页面标题中的名称，显示为「notion-auto （NOTION_AUTO_NAME）控制台」；不设则为「notion-auto 控制台」
# NOTION_AUTO_NAME = 我的电脑

# 设为 1 时，Dashboard 启动的子进程（Playwright / Warmup Executor）日志会同时输出到运行 dashboard 的终端，便于排查
# NOTION_AUTO_VERBOSE = 1

# Warmup Executor 配置文件路径：默认项目目录下 queue-sender.json；可设为相对路径（限定在项目目录内）或绝对路径
# QUEUE_SENDER_CONFIG = queue-sender.json

# Warmup Executor：Notion Integration Token，需将 Integration 加入 Warmup 相关数据库的 Collaborators
# NOTION_API_KEY = secret_xxx

# Gmail OAuth2：Warmup Executor 会用这组客户端凭据执行 Gmail Send/Reply/Open/Star，并通过 Google People API 执行 Add Contact。
# 实际 refresh_token 来自 Credential Registry.refresh_token。
# GMAIL_CLIENT_ID = xxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET = xxx

# Zoho Mail / Contacts（Provider=Zoho 时）：OAuth2 凭据；ZOHO_REGION 可选，默认 com（eu / com.cn 为其他区域）
# ZOHO_CLIENT_ID = xxx
# ZOHO_CLIENT_SECRET = xxx
# ZOHO_REDIRECT_URI = https://localhost
# ZOHO_REGION = com

# Microsoft 365（Provider=Microsoft 365 时）：OAuth2 凭据；需具备 Mail.ReadWrite / Mail.Send / Contacts.ReadWrite；M365_TENANT 可选，默认 common
# M365_CLIENT_ID = xxx
# M365_CLIENT_SECRET = xxx
# M365_TENANT = common

# SMTP 兼容方案不走这里的全局变量，而是走 Credential Registry.auth_config_json：
# - Send / Reply: auth_config_json.smtp
# - Open / Star: auth_config_json.imap
# - Add Contact: auth_config_json.contacts (当前为 CardDAV 兼容)

# Execute Window 无时区时使用的时区（如 +08:00 表示北京时间）；仅当 Notion 返回的 date 无 Z/+08:00 等后缀时生效
# EXECUTE_WINDOW_TZ = +08:00

# Warmup Executor 轮询不依赖以下参数；保留 QUEUE_THROTTLE_MAX_PER_DAY 仅用于兼容现有 Dashboard 启动逻辑
# QUEUE_THROTTLE_MAX_PER_DAY = 50

# 告警邮件（可选）：连续自动重启 >5 次时才会发一封（未配置则不发）
# NOTION_SMTP_HOST = smtp.gmail.com
# NOTION_SMTP_PORT = 587
# NOTION_SMTP_USER = send@email
# NOTION_SMTP_PASS = My_Password
# NOTION_ALERT_TO = inbox@email
